# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
HOST=0.0.0.0

# ── CORS ───────────────────────────────────────────────────────
# Allowed origins (comma-separated). In production, your Render URL.
# Dev: http://localhost:5173
# Prod: https://your-app.onrender.com
ALLOWED_ORIGINS=http://localhost:5173,https://temp-email-app.onrender.com,https://mailo.dpdns.org

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_MAX=30

# ── Upstream (Pomailbox) ───────────────────────────────────────
# Swappable upstream temp-email API endpoint.
POMAILBOX_PROXY=https://fasttoolshq.com/tools/temp-email-2/temp-email-api.php
FETCH_TIMEOUT_MS=15000
